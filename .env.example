# Copia questo file in .env e compila i valori (non committare .env).
# In produzione (Vercel): usa Environment Variables nel dashboard.
# Per Vercel serve un DB ospitato: imposta DATABASE_URL con una connection string Postgres
# (es. Vercel Postgres, Neon, Supabase). SQLite non è supportato in produzione su Vercel.

# Database Postgres (obbligatorio; per migrazioni con pooler usare anche DIRECT_URL)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
# Opzionale: connessione diretta per migrate (Neon/Vercel Postgres: usa URL non-pooler)
DIRECT_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Admin panel (middleware)
ADMIN_USER="admin"
ADMIN_PASSWORD="cambiami"

# Stripe (pagamenti)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Clerk (customer account; richieste per build e runtime)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/account/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/account/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/account"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/account"

# Email conferma ordine (opzionale; Resend)
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Biga Pizzeria <ordini@tuodominio.it>"
